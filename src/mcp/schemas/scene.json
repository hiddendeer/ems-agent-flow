{
    "entity_name": "scene",
    "description": "管理能源管理系统的运行场景，如正常运行、紧急停电、峰值用电、节能模式等。",
    "operations": {
        "create": { "endpoint": "/api/v1/scenes/", "method": "POST" },
        "get":    { "endpoint": "/api/v1/scenes/{id}", "method": "GET" },
        "update": { "endpoint": "/api/v1/scenes/{id}", "method": "PATCH" },
        "list":   { "endpoint": "/api/v1/scenes/", "method": "GET" },
        "delete": { "endpoint": "/api/v1/scenes/{id}", "method": "DELETE" },
        "activate": { "endpoint": "/api/v1/scenes/{id}/activate", "method": "POST" },
        "deactivate": { "endpoint": "/api/v1/scenes/{id}/deactivate", "method": "POST" }
    },
    "properties": {
        "name": {
            "type": "string",
            "description": "场景名称，如：正常运行、紧急停电、峰值用电、节能模式"
        },
        "type": {
            "type": "string",
            "enum": ["normal", "emergency", "peak_shaving", "energy_saving", "maintenance"],
            "description": "场景类型：normal(正常)、emergency(紧急)、peak_shaving(削峰)、energy_saving(节能)、maintenance(维护)"
        },
        "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "description": "优先级，1-10，数字越大优先级越高"
        },
        "description": {
            "type": "string",
            "description": "场景详细描述"
        },
        "conditions": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "device_id": { "type": "string" },
                    "metric": { "type": "string" },
                    "operator": { "type": "string", "enum": ["gt", "lt", "eq", "gte", "lte"] },
                    "value": { "type": "number" }
                }
            },
            "description": "触发条件，如：当电表读数大于1000时触发"
        },
        "actions": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "device_id": { "type": "string" },
                    "action": { "type": "string" },
                    "parameters": { "type": "object" }
                }
            },
            "description": "场景激活时执行的操作，如：关闭某些设备、调整功率等"
        },
        "metadata": {
            "type": "object",
            "description": "场景元数据，如创建时间、创建人、标签等"
        },
        "is_active": {
            "type": "boolean",
            "description": "场景是否处于激活状态"
        }
    },
    "required": ["name", "type", "priority"]
}
