{
    "entity_name": "device",
    "description": "管理工业设备，如电表、逆变器、电池等。",
    "operations": {
        "create": { "endpoint": "/api/v1/devices/", "method": "POST" },
        "get":    { "endpoint": "/api/v1/devices/{id}", "method": "GET" },
        "update": { "endpoint": "/api/v1/devices/{id}", "method": "PATCH" },
        "list":   { "endpoint": "/api/v1/devices/", "method": "GET" },
        "delete": { "endpoint": "/api/v1/devices/{id}", "method": "DELETE" }
    },
    "properties": {
        "name": {
            "type": "string",
            "description": "设备名称，如：西侧总电表"
        },
        "type": {
            "type": "string",
            "description": "设备类型，如：电表、逆变器、电池"
        },
        "location": {
            "type": "string",
            "description": "安装位置，如：园区配电室 1-1"
        },
        "metadata": {
            "type": "object",
            "description": "设备元数据，如品牌、协议、容量等"
        }
    },
    "required": ["name", "type"]
}
