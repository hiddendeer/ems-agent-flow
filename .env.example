# 基础配置
APP_NAME="FastAPI EMS"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# API 配置
API_V1_PREFIX=/api/v1

# 服务器配置
HOST=0.0.0.0
PORT=8000
WORKERS=1

# CORS 配置
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Agent & LLM 配置 (重要：请勿将真实 Key 提交至 Git)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4
DEFAULT_MODEL=openai:glm-4.0
TAVILY_API_KEY=your_tavily_api_key_here

# 数据库配置
DB_HOST=your_database_host_here
DB_PORT=3306
DB_USER=your_database_user_here
DB_PASSWORD=your_database_password_here
DB_NAME=your_database_name_here
DB_ECHO=false

# 数据库连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# 多数据库逻辑库名
DB_USER_NAME=myems_user_db
DB_SYSTEM_NAME=myems_system_db
DB_REPORTING_NAME=myems_reporting_db

# InfluxDB 配置
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_influxdb_token_here
INFLUXDB_ORG=your_org_here
INFLUXDB_BUCKET=your_bucket_here
